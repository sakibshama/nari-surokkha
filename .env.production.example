# ============================================================
# Nari Surokkha — PRODUCTION environment (single VPS)
#
# Copy to `.env.production` on the server and fill every value.
# NEVER commit the real .env.production. Keep a secure backup.
#
# Generate strong secrets:
#   JWT secrets:            openssl rand -hex 48
#   CONFIG_ENCRYPTION_KEY:  openssl rand -hex 32
#   passwords / API keys:   openssl rand -base64 24
#
# Replace `example.com` everywhere with your real domain.
# ============================================================

# ─── Domain (used by nginx + CORS) ─────────────────────────
DOMAIN=example.com

# ─── Container images (set automatically by CI on deploy) ──
# For a manual/local build leave these; CI overrides REGISTRY + TAG.
REGISTRY=ghcr.io/YOUR_GITHUB_USER/nari-surokkha
TAG=latest

# ─── Server ────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
HOST=0.0.0.0
API_BASE_URL=https://api.example.com

# ─── Database (PostgreSQL + PostGIS) ───────────────────────
POSTGRES_DB=nari_surokkha
POSTGRES_USER=nari_user
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
# Must match the three values above; host is the compose service name.
DATABASE_URL=postgresql://nari_user:CHANGE_ME_strong_db_password@postgres:5432/nari_surokkha

# ─── Redis ─────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_strong_redis_password
REDIS_URL=redis://:CHANGE_ME_strong_redis_password@redis:6379

# ─── Auth / JWT (>= 64 chars each) ─────────────────────────
JWT_SECRET=CHANGE_ME_openssl_rand_hex_48
JWT_REFRESH_SECRET=CHANGE_ME_openssl_rand_hex_48_different
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# ─── Secret encryption (for admin-managed SMS keys) ────────
CONFIG_ENCRYPTION_KEY=CHANGE_ME_openssl_rand_hex_32

# ─── CORS — MUST be explicit (wildcard is rejected in prod) ─
CORS_ORIGINS=https://admin.example.com,https://police.example.com
WS_CORS_ORIGINS=https://admin.example.com,https://police.example.com

# ─── Evidence storage (server disk, bind-mounted for backup) ─
# Host path that gets mounted into the API container at /app/uploads.
UPLOADS_DIR=/opt/nari-surokkha/data/uploads
STORAGE_LOCAL_DIR=/app/uploads

# ─── TURN relay (WebRTC streaming across networks) ─────────
# Must match the credential hardcoded in the mobile app / portals.
TURN_PASSWORD=CHANGE_ME_turn_password

# ─── ML Service (internal) ─────────────────────────────────
ML_SERVICE_URL=http://ml-service:8000
ML_SERVICE_API_KEY=CHANGE_ME_shared_ml_secret

# ─── Firebase (push notifications — optional but recommended) ─
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ─── SMS fallback (live config is managed in the Admin Portal) ─
SMS_PROVIDER=mock
SMS_API_KEY=
SMS_API_SECRET=
SMS_SENDER_ID=NariSurokkha
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ─── Portal build-time API URLs (baked into the static bundles) ─
ADMIN_VITE_API_URL=https://api.example.com/api/v1
POLICE_VITE_API_URL=https://api.example.com/api/v1
PUBLIC_WS_URL=https://api.example.com

# ─── Monitoring (optional) ─────────────────────────────────
SENTRY_DSN=

# ─── Logging ───────────────────────────────────────────────
LOG_LEVEL=info
LOG_PRETTY=false
