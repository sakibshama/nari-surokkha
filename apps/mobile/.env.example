# ============================================================
# Nari Surokkha — Mobile App Environment Variables
# Copy this file to .env and fill in real values
# NEVER commit .env to version control
# ============================================================

# ─── API ────────────────────────────────────────────────────
API_BASE_URL=http://YOUR_LAPTOP_IP:3001/api/v1
# Note: 10.0.2.2 is Android emulator's localhost. 
# For testing on a real device on the same Wi-Fi network, 
# replace YOUR_LAPTOP_IP with your laptop's local IPv4 address (e.g., 192.168.1.5).

# ─── WebSocket ─────────────────────────────────────────────
WS_URL=http://10.0.2.2:3001

# ─── Maps ──────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ─── Firebase ──────────────────────────────────────────────
# Add your google-services.json in android/app/ directory
# Do NOT put Firebase config here — use the JSON file

# ─── App ────────────────────────────────────────────────────
APP_ENV=development
APP_BUNDLE_ID=com.narisurokkha.app
EMERGENCY_PHONE=999
