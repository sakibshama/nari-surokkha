# ============================================================
# Nari Surokkha — Backend API Environment Variables
# Copy this file to .env and fill in real values
# NEVER commit .env to version control
# ============================================================

# ─── Server ────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
API_BASE_URL=http://localhost:3001

# ─── Database (PostgreSQL + PostGIS) ───────────────────────
DATABASE_URL=postgresql://nari_user:your_password@localhost:5432/nari_surokkha_dev
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ─── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ─── Auth / JWT ────────────────────────────────────────────
JWT_SECRET=change_this_to_a_very_long_random_secret_at_least_64_chars
JWT_REFRESH_SECRET=change_this_refresh_secret_also_very_long_random_string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# ─── Password Hashing ──────────────────────────────────────
ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=4

# ─── CORS ──────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3002

# ─── Firebase (Push Notifications) ─────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ─── SMS Gateway ───────────────────────────────────────────
# NOTE: The live SMS provider is normally configured at runtime from the
# Admin Portal (Settings → SMS Gateway) and stored ENCRYPTED in the DB.
# The values below are only a FALLBACK used before any admin config exists.
SMS_PROVIDER=mock
# Options: mock | sslcommerz | bdbulksms | twilio
SMS_API_KEY=your_sms_api_key
# For SMS_PROVIDER=twilio, SMS_API_SECRET is the Twilio Auth Token and is
# ALSO used to validate the inbound /alerts/sms-webhook signature.
SMS_API_SECRET=your_sms_api_secret
SMS_SENDER_ID=NariSurokkha
# Twilio fallbacks (optional — Admin Portal config takes precedence)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ─── Secret Encryption (REQUIRED for Admin-managed SMS keys) ─
# 32-byte key used to encrypt SMS provider secrets at rest.
# Generate with:  openssl rand -hex 32
CONFIG_ENCRYPTION_KEY=

# ─── Evidence Storage ──────────────────────────────────────
# By default (no AWS_S3_BUCKET set) evidence is stored on the Node server's
# local disk. On a VPS set an absolute path with enough space + backups:
#   STORAGE_LOCAL_DIR=/var/lib/nari-surokkha/uploads
# When empty, files go to "<api-working-dir>/uploads".
STORAGE_LOCAL_DIR=

# ─── S3-Compatible Storage (optional alternative) ──────────
STORAGE_PROVIDER=minio
# Options: minio | aws-s3 | cloudflare-r2
S3_ENDPOINT=http://localhost:9000
S3_REGION=ap-southeast-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_EVIDENCE=nari-evidence
S3_BUCKET_PUBLIC=nari-public

# ─── ML Service ────────────────────────────────────────────
ML_SERVICE_URL=http://localhost:8000
ML_SERVICE_API_KEY=change_this_ml_api_key

# ─── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW_MS=900000
RATE_LIMIT_GLOBAL_MAX=100
RATE_LIMIT_GLOBAL_WINDOW_MS=60000

# ─── Logging ───────────────────────────────────────────────
LOG_LEVEL=info
# Options: trace | debug | info | warn | error | fatal
LOG_PRETTY=true

# ─── Sentry (Error Tracking) ───────────────────────────────
SENTRY_DSN=

# ─── WebSocket ─────────────────────────────────────────────
WS_CORS_ORIGINS=http://localhost:3000,http://localhost:3002
