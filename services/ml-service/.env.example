# ============================================================
# Nari Surokkha — ML Service Environment Variables
# Copy to .env and fill in real values. NEVER commit .env.
# ============================================================

# Shared secret the backend API must present via the X-API-Key header.
# When set, all analysis endpoints require a matching key.
ML_SERVICE_API_KEY=change_this_ml_api_key

# Comma-separated CORS allow-list (never use "*" in production).
ML_ALLOWED_ORIGINS=http://localhost:3001
